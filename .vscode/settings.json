{
  "editor.formatOnSave": true,
  "emmet.includeLanguages": {
    "javascript": "javascriptreact"
  },
  "emmet.syntaxProfiles": {
    "javascript": "jsx"
  },
  "emmet.showSuggestionsAsSnippets": true,
  "editor.fontLigatures": true,
  "files.exclude": {
    "**/.DS_Store": true,
    "**/.git": true,
    "**/node_modules": true,
    "**/design": true,
    "**/*.sketch": true,
    "**/*.studio": true
  },
  "html.format.enable": false,
  "search.exclude": {
    "**/bower_components": true,
    "**/node_modules": true,
    "**/build/*.js": true,
    "index.*": true
  }
}
